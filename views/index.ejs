<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0"
    />
    <title>NexVault — Crypto Investment Platform</title>
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Space+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <link rel="stylesheet" href="/index.css" />
  </head>
  <body>
    <!-- ============================================================
     AUTH SCREEN
============================================================ -->
    <div class="screen active" id="authScreen">
      <div class="hero">
        <div class="logowrap">
          <div class="logoico">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2"
            >
              <path
                d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
              />
            </svg>
          </div>
          <span class="logoname">NexVault</span>
        </div>
        <div class="htitle" id="aTitle">Welcome <span>back</span></div>
        <div class="hsub" id="aSub">
          Sign in to access your portfolio and manage your crypto assets
          securely.
        </div>
      </div>

      <div class="tabrow">
        <div class="atab on" id="tabIn" onclick="switchTab('in')">Sign in</div>
        <div class="atab" id="tabUp" onclick="switchTab('up')">
          Create account
        </div>
      </div>
      <!-- end scbody -->
      <%- include("partials/login") %>
    
      <div class="trustrow" id="trustRow">
        <div class="ti">
          <div class="tico">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#00d4aa"
              stroke-width="1.5"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
          </div>
          <span class="tlbl">SSL Secured</span>
        </div>
        <div class="ti">
          <div class="tico">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#3b82f6"
              stroke-width="1.5"
            >
              <rect x="5" y="2" width="14" height="20" rx="2" />
              <line x1="12" y1="18" x2="12.01" y2="18" />
            </svg>
          </div>
          <span class="tlbl">2FA Support</span>
        </div>
        <div class="ti">
          <div class="tico">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#f59e0b"
              stroke-width="1.5"
            >
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
          </div>
          <span class="tlbl">KYC Verified</span>
        </div>
        <div class="ti">
          <div class="tico">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#22c55e"
              stroke-width="1.5"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </div>
          <span class="tlbl">Regulated</span>
        </div>
      </div>
    </div>

    <script src="/linked.js"></script>
  </body>
</html>
