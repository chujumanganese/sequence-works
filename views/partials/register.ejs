        >
        <polyline points="6 9 12 15 18 9" />
        </svg>
    </div>
    </div>
    <div class="field">
    <label class="flabel">Password</label>
    <div class="fwrap">
        <svg
        class="ficon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#64748b"
        stroke-width="1.5"
        >
        <rect x="3" y="11" width="18" height="11" rx="2" />
        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        <input
        name="password1"
        class="finput"
        id="suPass"
        type="password"
        placeholder="Create a strong password"
        oninput="
            chkStr();
            valSU();
        "
        />
        <span class="eyebtn" onclick="toggleEye('suPass')"
        ><svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#64748b"
            stroke-width="1.5"
        >
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
            <circle cx="12" cy="12" r="3" /></svg
        ></span>
    </div>
    <div class="strbar">
        <div class="sb" id="sb1"></div>
        <div class="sb" id="sb2"></div>
        <div class="sb" id="sb3"></div>
        <div class="sb" id="sb4"></div>
    </div>
    <div class="strlbl" id="strLbl" style="color: var(--muted)"></div>
    </div>
    <div class="field">
    <label class="flabel">Confirm password</label>
    <div class="fwrap">
        <svg
        class="ficon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#64748b"
        stroke-width="1.5"
        >
        <rect x="3" y="11" width="18" height="11" rx="2" />
        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        <input
        name="password2"
        class="finput"
        id="suConfirm"
        type="password"
        placeholder="Re-enter password"
        oninput="valSU()"
        />
    </div>
    <div class="ferror" id="suConfirmErr">Passwords do not match</div>
    </div>
    <div class="consentbox">
    <label class="crow">
        <input
        type="checkbox"
        id="chkTerms"
        onchange="valSU()"
        style="margin-top: 3px; accent-color: #00d4aa; flex-shrink: 0"
        />
        <span class="ctxt"
        >I agree to NexVault's <a href="#">Terms of Service</a> and
        <a href="#">Privacy Policy</a></span
        >
    </label>
    <label class="crow">
        <input
        type="checkbox"
        id="chkAge"
        onchange="valSU()"
        style="margin-top: 3px; accent-color: #00d4aa; flex-shrink: 0"
        />
        <span class="ctxt">I confirm I am 18 years or older</span>
    </label>
    </div>
    <button type="submit" class="pbtn" id="suBtn" disabled>
    Create my account
    </button>
    <div class="securenote">
    🔒 Your data is encrypted and never shared
    </div>
</form>
<script src="/reg.js"></script>