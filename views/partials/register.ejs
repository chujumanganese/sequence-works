<form method="post" action="/register" id="suForm" style="display: none">
    <div id="error_of_pas" style="color: red; text-align: center;"></div><br>
    <div class="nrow">
    <div class="field">
        <label class="flabel">First name</label>
        <div class="fwrap">
        <input
            name="firstname"
            class="finput noi"
            id="suFirst"
            type="text"
            placeholder="John"
            oninput="valSU()"
        />
        </div>
    </div>
    <div class="field">
        <label class="flabel">Last name</label>
        <div class="fwrap">
        <input
            name="lastname"
            class="finput noi"
            id="suLast"
            type="text"
            placeholder="Doe"
            oninput="valSU()"
        />
        </div>
    </div>
    </div>
    <div class="field">
    <label class="flabel">Email address</label>
    <div class="fwrap">
        <svg
        class="ficon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#64748b"
        stroke-width="1.5"
        >
        <path
            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
        />
        <polyline points="22,6 12,13 2,6" />
        </svg>
        <input
        name="email"
        class="finput"
        id="suEmail"
        type="email"
        placeholder="you@example.com"
        oninput="valSU()"
        />
    </div>
    <div class="ferror" id="suEmailErr">Please enter a valid email</div>
    </div>
    <div class="field">
    <label class="flabel">Phone number</label>
    <div class="fwrap">
        <svg
        class="ficon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#64748b"
        stroke-width="1.5"
        >
        <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"
        />
        </svg>
        <input
        name="phonenumber"
        class="finput"
        id="suPhone"
        type="tel"
        placeholder="+1 555 000 0000"
        oninput="valSU()"
        />
    </div>
    </div>
    <div class="field">
    <label class="flabel">Country of residence</label>
    <div class="fwrap">
        <svg
        class="ficon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#64748b"
        stroke-width="1.5"
        >
        <circle cx="12" cy="12" r="10" />
        <line x1="2" y1="12" x2="22" y2="12" />
        <path
            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
        />
        </svg>
