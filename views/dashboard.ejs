              viewBox="0 0 24 24"
              fill="none"
              stroke="#64748b"
              stroke-width="2"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </div>
        </div>

        <!-- CHANGE PASSWORD FORM (hidden by default) -->
        <div
          id="changePwForm"
          style="
            display: none;
            background: var(--card);
            border: 1.5px solid var(--border);
            border-radius: 16px;
            padding: 18px;
            margin-bottom: 20px;
          "
        >
          <div style="font-size: 14px; font-weight: 700; margin-bottom: 14px">
            Change Password
          </div>
          <div class="field">
            <label class="flabel">Current password</label>
            <div class="fwrap">
              <svg
                class="ficon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#64748b"
                stroke-width="1.5"
              >
                <rect x="3" y="11" width="18" height="11" rx="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg
              ><input
                class="finput"
                id="pwCurrent"
                type="password"
                placeholder="Enter current password"
              />
            </div>
          </div>
          <div class="field">
            <label class="flabel">New password</label>
            <div class="fwrap">
              <svg
                class="ficon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#64748b"
                stroke-width="1.5"
              >
                <rect x="3" y="11" width="18" height="11" rx="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg
              ><input
                class="finput"
                id="pwNew"
                type="password"
                placeholder="Enter new password"
              />
            </div>
          </div>
          <div class="field">
            <label class="flabel">Confirm new password</label>
            <div class="fwrap">
              <svg
                class="ficon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#64748b"
                stroke-width="1.5"
              >
                <rect x="3" y="11" width="18" height="11" rx="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg
              ><input
                class="finput"
                id="pwConfirm"
                type="password"
                placeholder="Confirm new password"
              />
            </div>
          </div>
          <div style="display: flex; gap: 10px">
            <button
              class="gbtn"
              style="margin-bottom: 0; flex: 1"
              onclick="closeChangePass()"
            >
              Cancel
            </button>
            <button
              class="pbtn"
              style="margin-bottom: 0; flex: 2"
              onclick="submitChangePass()"
            >
              Update Password
            </button>
          </div>
        </div>

        <!-- DANGER ZONE -->
        <div
          style="
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            letter-spacing: 0.5px;
            margin-bottom: 10px;
            padding-left: 4px;
          "
        >
          ACCOUNT
        </div>
        <div
          style="
            background: var(--card);
            border: 1.5px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 8px;
          "
        >
          <div
            onclick="doLogout()"
            style="
              display: flex;
              align-items: center;
              gap: 12px;
              padding: 15px 16px;
              cursor: pointer;
              border-bottom: 1px solid var(--border);
            "
          >
            <div
              style="
                width: 38px;
                height: 38px;
                border-radius: 11px;
                background: rgba(239, 68, 68, 0.1);
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
              "
            >
              <svg
                width="17"
                height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#ef4444"
                stroke-width="1.5"
              >
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                <polyline points="16 17 21 12 16 7" />
                <line x1="21" y1="12" x2="9" y2="12" />
              </svg>
            </div>
            <div style="flex: 1">
              <div style="font-size: 14px; font-weight: 600; color: var(--red)">
                Sign Out
              </div>
              <div
                style="font-size: 12px; color: var(--muted); margin-top: 2px"
              >
                Log out of your NexVault account
              </div>
            </div>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#64748b"
              stroke-width="2"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </div>
          <div
            style="
              display: flex;
              align-items: center;
              gap: 12px;
              padding: 15px 16px;
              cursor: pointer;
            "
          >
            <div
              style="
                width: 38px;
                height: 38px;
                border-radius: 11px;
                background: rgba(239, 68, 68, 0.1);
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
              "
            >
              <svg
                width="17"
                height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#ef4444"
                stroke-width="1.5"
              >
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6l-1 14H6L5 6" />
                <path d="M10 11v6" />
                <path d="M14 11v6" />
                <path d="M9 6V4h6v2" />
              </svg>
            </div>
            <div style="flex: 1">
              <div style="font-size: 14px; font-weight: 600; color: var(--red)">
                Delete Account
              </div>
              <div
                style="font-size: 12px; color: var(--muted); margin-top: 2px"
              >
                Permanently remove your account
              </div>
            </div>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#64748b"
              stroke-width="2"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </div>
        </div>

        <div
          style="
            text-align: center;
            padding: 16px 0;
            font-size: 11px;
            color: var(--muted);
          "
        >
          NexVault v1.0 &nbsp;·&nbsp; &copy; 2025 All rights reserved
        </div>
      </div>
    </div>
    <script src="linked.js"></script>
</body>
</html>